    "ffmpeg-static": "^5.2.0",
    "node-cron": "^4.2.1",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
